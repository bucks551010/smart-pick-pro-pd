# ============================================================
# Smart Pick Pro — Secrets Configuration
# ============================================================
#
# HOW TO USE:
#   1. Copy this file to .streamlit/secrets.toml:
#        cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Replace the placeholder values below with your real keys.
#   3. Restart the app (streamlit run Smart_Picks_Pro_Home.py).
#
# IMPORTANT:
#   - .streamlit/secrets.toml is in .gitignore — it will NEVER be
#     committed to version control. Your keys stay private.
#   - You can also enter keys in the ⚙️ Settings page at runtime,
#     or set them as environment variables.
#
# WHERE TO GET KEYS:
#   Stripe                      → https://dashboard.stripe.com/developers
# ============================================================

# ── Required for DraftKings Pick6 data ────────────────────────
ODDS_API_KEY = "your_the_odds_api_key"                 # https://the-odds-api.com/

# ── Required for Stripe payments ─────────────────────────────
STRIPE_SECRET_KEY = "sk_live_..."                      # Stripe Dashboard → Developers → API Keys
STRIPE_PUBLISHABLE_KEY = "pk_live_..."
STRIPE_PRICE_ID = "price_..."                          # Stripe Dashboard → Products
STRIPE_WEBHOOK_SECRET = "whsec_..."                    # Stripe Dashboard → Webhooks (optional but recommended)

# ── Required for production mode ─────────────────────────────
# MUST be "true" to enforce subscription gates in live deployments.
# When absent or not "true", all premium features are unlocked (dev mode).
SMARTAI_PRODUCTION = "true"
APP_URL = "https://your-app.streamlit.app"             # Your deployed app URL (no trailing slash)

# ── Optional ─────────────────────────────────────────────────
DB_PATH = "db/smartai_nba.db"                          # Override default SQLite path
LOG_LEVEL = "INFO"                                     # DEBUG, INFO, WARNING, ERROR

# ── Azure AD / MSAL SSO (optional) ────────────────────────────────────────
# Enable Microsoft SSO by filling in the four required values below.
# Leave blank (or omit) to keep password-only authentication.
#
# How to register the app:
#   Azure Portal → Azure Active Directory → App registrations → New registration
#   Set Redirect URI to your APP_URL + "/callback" (e.g. https://your-app.streamlit.app/callback)
#   After registering: Certificates & secrets → New client secret
#   Optional: expose /groups claim via Token configuration → Add groups claim
#
AZURE_TENANT_ID        = "your-aad-tenant-id"          # Azure AD → Overview → Tenant ID
AZURE_CLIENT_ID        = "your-aad-app-client-id"      # App registrations → Overview → Application (client) ID
AZURE_CLIENT_SECRET    = "your-aad-client-secret"      # App registrations → Certificates & secrets
AZURE_REDIRECT_URI     = "https://your-app.streamlit.app/callback"
AZURE_ADMIN_GROUP_ID   = ""                            # Optional: AAD group object-ID whose members become admins

# ── Session security ───────────────────────────────────────────────────────
# Idle inactivity timeout in seconds before the session is purged (CWE-613).
# Default: 1800 (30 minutes).  Minimum enforced: 60 seconds.
SESSION_IDLE_TIMEOUT_SECONDS = 1800

# ── Secret management notes ────────────────────────────────────────────────
# JWT_SECRET — if your deployment uses JWT tokens, set a strong, stable random
# value here so that tokens survive app restarts.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
# Leaving this unset causes an ephemeral key (tokens invalidated on restart).
JWT_SECRET = ""   # Leave empty for ephemeral (dev) or set a 64-char hex string
