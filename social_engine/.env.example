# ─── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
TIMEZONE=America/New_York
BRAND_URL=https://smartpickpro.app
WATERMARK_TEXT=SmartPickPro.app

# ─── Database (shared with main app) ────────────────────────
# Postgres example: postgres://user:pass@host:5432/dbname
# SQLite example:   sqlite:////absolute/path/to/smartai_nba.db
DATABASE_URL=sqlite:////app/db/smartai_nba.db

# ─── LLM (Gemini — free tier) ────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── X / Twitter (OAuth1 user context, posting to own account) ──
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ─── Meta Graph API (Facebook Page + Instagram Business + Threads) ──
# Long-lived Page Access Token (exchange via Graph API Explorer)
META_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token
META_PAGE_ID=your-facebook-page-id
META_INSTAGRAM_BUSINESS_ID=your-instagram-business-account-id
META_THREADS_USER_ID=your-threads-user-id

# ─── TikTok Content Posting API ──────────────────────────────
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ─── Webhook security ────────────────────────────────────────
WEBHOOK_SHARED_SECRET=spp_wh_2026_xK9mRqTv8nLpQ3jW
# ─── Scheduler toggles ───────────────────────────────────────
SCHEDULER_ENABLED=true
RECAP_HOUR_LOCAL=9                # 9am morning recap
PREGAME_LEAD_HOURS=2              # Post 2h before each game
BRANDING_CRON=0 14 * * 2,5        # Tue & Fri 2pm — brand/CTA push
