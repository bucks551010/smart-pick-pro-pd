{
    # Caddy enables HTTPS automatically when using a domain name.
    # For local/dev usage with :80, set auto_https off temporarily.
}

:443, :80 {
    # ── SEO: Serve static files (robots.txt, sitemap.xml, manifest.json) ──
    handle /robots.txt {
        root * /app/static
        file_server
        header Cache-Control "public, max-age=86400"
    }
    handle /sitemap.xml {
        root * /app/static
        file_server
        header Cache-Control "public, max-age=3600"
        header Content-Type "application/xml; charset=utf-8"
    }
    handle /manifest.json {
        root * /app/static
        file_server
        header Cache-Control "public, max-age=604800"
    }

    # ── Serve logo/assets for OG image crawlers ──
    handle /assets/* {
        root * /app
        file_server
        header Cache-Control "public, max-age=2592000, immutable"
    }

    # ── API proxy ──
    handle /api/* {
        reverse_proxy api:8000
    }

    # ── OG preview: serve meta-tag page to social media link crawlers ──
    # Intercepts known bots (iMessage/Applebot, Slack, Discord, Twitter/X,
    # WhatsApp/Facebook, LinkedIn, Telegram, Pinterest) and returns the static
    # og.html so link unfurls show the correct title, description, and logo.
    # Real browsers pass straight through to Streamlit.
    @bots {
        path /
        expression `{header.User-Agent} =~ "(?i)(facebookexternalhit|Slackbot|Twitterbot|LinkedInBot|Discordbot|TelegramBot|Applebot|WhatsApp|Pinterest|Embedly|Iframely|OGProxy|preview\\.js|MetaInspector|OpenLinkProfiler|Screaming Frog)"`
    }
    handle @bots {
        root * /app/static
        rewrite * /og.html
        file_server
    }

    # ── App proxy ──
    handle {
        reverse_proxy app:8501
    }

    # ── Global SEO + Security Headers ──
    header {
        # Security
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

        # SEO Performance
        X-Robots-Tag "index, follow"
        Link "</manifest.json>; rel=manifest"
    }

    # ── Compression ──
    encode gzip zstd
}
